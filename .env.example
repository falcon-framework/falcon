# Shared local-development env for `packages/infra/alchemy.run.ts`.
# Copy to `.env` and adjust the values for your machine.

# Postgres used by auth-server and connect-service
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/falcon

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# First-party browser origins allowed to call Falcon services
CORS_ORIGIN=http://localhost:3002,http://localhost:3010,http://localhost:3011

# Falcon Connect JWT signing
# Generate an RSA keypair and paste the PEM values here.
CONNECT_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
CONNECT_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# Optional: defaults to 300 seconds when omitted
CONNECT_ACCESS_TOKEN_TTL_SECONDS=300
