{
  "name": "falcon",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "effect": "^3.21.0",
      "@effect/language-service": "^0.80.0",
      "@effect/platform": "^0.96.0",
      "@effect/platform-browser": "^0.76.0",
      "@effect/rpc": "^0.75.0",
      "@effect/vitest": "^0.29.0",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260317.1",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.2",
      "alchemy": "^0.87.0",
      "wrangler": "^4.54.0",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "typescript": "^5.9.3",
      "@orpc/client": "^1.12.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "dev:server": "nx run-many -t dev --projects=server",
    "db:push": "nx run-many -t db:push --projects=@falcon-framework/db",
    "db:studio": "nx run-many -t db:studio --projects=@falcon-framework/db",
    "db:generate": "nx run-many -t db:generate --projects=@falcon-framework/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@falcon-framework/db",
    "deploy": "nx run-many -t deploy --projects=@falcon-framework/infra",
    "destroy": "nx run-many -t destroy --projects=@falcon-framework/infra",
    "check": "oxlint && oxfmt --write",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "test": "vitest run",
    "prepare": "effect-tsgo patch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release-packages": "changeset publish",
    "sdk:build": "bun run --cwd packages/sdk build",
    "sdk:check-types": "bun run --cwd packages/sdk check-types",
    "sdk:publint": "bun run --cwd packages/sdk publint"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/rpc": "catalog:",
    "@falcon-framework/env": "workspace:*",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@cloudflare/workers-types": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/tsgo": "0.0.15",
    "@effect/vitest": "catalog:",
    "@falcon-framework/config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "lefthook": "^2.0.13",
    "nx": "^21.5.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
