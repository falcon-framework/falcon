# The monorepo loads the repo root `.env` via `packages/infra/alchemy.run.ts`.
# Use the repo root `.env.example` as the single source
# of truth for shared Auth / Connect worker bindings, including:
# - DATABASE_URL
# - BETTER_AUTH_SECRET
# - BETTER_AUTH_URL
# - CORS_ORIGIN
# - CONNECT_JWT_PRIVATE_KEY
# - CONNECT_JWT_PUBLIC_KEY
# - CONNECT_ACCESS_TOKEN_TTL_SECONDS
#
# No additional auth-server-only env vars are currently required here.
