# Copy to `.env.local` for local dev. URLs must match your running auth-server and connect-service.

# Better Auth base URL (Falcon Auth / auth-server)
VITE_FALCON_AUTH_URL=http://localhost:3000

# Must match `falcon_auth_app.publishable_key` for the source app in Postgres (see SEED.sql)
VITE_FALCON_PUBLISHABLE_KEY=pk_demo_source

# Connect service base URL (no trailing /v1)
VITE_CONNECT_URL=http://localhost:3001

# This app's row in `falcon_app.id` (source)
VITE_FALCON_APP_ID=a0000001-0000-4000-8000-000000000001

# Partner app's `falcon_app.id` (target)
VITE_PEER_APP_ID=a0000002-0000-4000-8000-000000000002

# Partner app origin (for redirects and returnUrl validation on the target)
VITE_PEER_APP_ORIGIN=http://localhost:3011

# This demo’s own origin (connection list “See in …” links)
VITE_APP_PUBLIC_ORIGIN=http://localhost:3010

# Falcon console web app (orgs, connections, settings)
VITE_FALCON_CONSOLE_URL=http://localhost:3002
