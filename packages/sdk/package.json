{
  "name": "@falcon-framework/sdk",
  "version": "0.3.0",
  "private": false,
  "description": "FALCON SDK — use Falcon Auth as your identity provider. Drop-in React components for sign-in, sign-up, and user management. Like Clerk, but self-hosted.",
  "keywords": [
    "auth",
    "authentication",
    "connect",
    "falcon",
    "identity",
    "react",
    "sdk",
    "sign-in",
    "single sign-on",
    "sso",
    "unified authentication"
  ],
  "homepage": "https://falcon-framework.com",
  "bugs": {
    "url": "https://github.com/falcon-framework/falcon/issues"
  },
  "license": "MIT",
  "author": "FALCON",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/falcon-framework/falcon.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./connect": {
      "types": "./dist/connect.d.ts",
      "import": "./dist/connect.js",
      "default": "./dist/connect.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "publint": "publint",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "publint": "^0.3.18",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
