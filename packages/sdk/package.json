{
  "name": "@falcon-framework/sdk",
  "version": "0.1.0",
  "private": false,
  "description": "FALCON SDK — use Falcon Auth as your identity provider. Drop-in React components for sign-in, sign-up, and user management. Like Clerk, but self-hosted.",
  "keywords": [
    "auth",
    "authentication",
    "connect",
    "falcon",
    "identity",
    "react",
    "sdk",
    "sign-in",
    "single sign-on",
    "sso",
    "unified authentication"
  ],
  "homepage": "https://falcon-framework.com",
  "bugs": {
    "url": "https://github.com/falcon-framework/falcon/issues"
  },
  "license": "MIT",
  "author": "FALCON",
  "repository": {
    "type": "git",
    "url": "https://github.com/falcon-framework/falcon.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./react": {
      "default": "./src/react.ts"
    },
    "./server": {
      "default": "./src/server.ts"
    }
  },
  "scripts": {},
  "dependencies": {
    "better-auth": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@falcon-framework/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
